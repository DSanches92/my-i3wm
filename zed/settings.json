// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "theme": {
    "mode": "dark",
    "light": "Catppuccin Latte",
    "dark": "Catppuccin Macchiato"
  },
  "tab_size": 2,
  "hard_tabs": false,
  "buffer_font_size": 14,
  "buffer_font_family": "GeistMono Nerd Font Mono",
  "buffer_font_weight": 600,
  "buffer_line_height": { "custom": 1.4 },
  "buffer_font_features": { "calt": true },
  "ui_font_family": ".SystemUIFont",
  "ui_font_size": 16,
  "icon_theme": {
    "mode": "dark",
    "light": "Catppuccin Macchiato",
    "dark": "Catppuccin Macchiato"
  },
  "base_keymap": "VSCode",
  "vim_mode": false,
  "relative_line_numbers": "enabled",
  "toolbar": { "breadcrumbs": false, "quick_actions": false },
  "project_panel": {
    "entry_spacing": "standard",
    "auto_fold_dirs": false,
    "dock": "right"
  },
  "tabs": { "file_icons": true, "git_status": true },
  "git": {
    "inline_blame": { "enabled": false },
    "git_gutter": "tracked_files"
  },
  "scrollbar": { "show": "never" },
  "cursor_blink": false,
  "current_line_highlight": "gutter",
  "cursor_shape": "bar",
  "telemetry": { "metrics": false, "diagnostics": false },
  "indent_guides": { "enabled": true, "coloring": "indent_aware" },
  "remove_trailing_whitespace_on_save": true,
  "ensure_final_newline_on_save": true,
  "autosave": "on_focus_change",
  "show_edit_predictions": false,
  "edit_predictions": { "provider": "zed" },
  "vertical_scroll_margin": 3,
  "preview_tabs": {
    "enabled": true,
    "enable_preview_from_file_finder": true
  }
}
